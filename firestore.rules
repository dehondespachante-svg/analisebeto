rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // SGDW: tunnel URL publica (nao sensivel) pode ser lida por qualquer um.
    // Escrita exige o token do servidor para evitar sobrescrita indevida.
    match /sgdw-config/{doc} {
      allow read: if true;
      allow write: if request.resource.data.token == "6ad74bc2cdc8d84953ea21ad89c25715d49ad614757b8aea5c599050b5d6e6dc";
    }
  }
}
